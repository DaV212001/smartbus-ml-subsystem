# SmartBus ML Subsystem Environment Configuration

# Service Settings
PORT=8000
HOST=0.0.0.0
ENV=development

# Storage Paths
DATA_DIR=./data
MODELS_DIR=./models

# Model Parameters
TRAINING_SAMPLE_SIZE=2000
FRAUD_SAMPLE_SIZE=5000
ANOMALY_CONTAMINATION=0.05

# Shared secret — when set, every non-/health request must include a matching
# X-Internal-Token header. Must match ML_SERVICE_TOKEN on the NestJS side.
ML_INTERNAL_TOKEN=
